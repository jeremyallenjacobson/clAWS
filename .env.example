# Vocareum AWS Credentials
#
# Get these from: Vocareum course page → "AWS Details"
#
# Paste your values below (replace the ... placeholders).
# Do NOT share this file or commit it to git.
#
# This file is sourced with: source .env
# Credentials exist only in the current terminal session.
# Close the terminal or delete clAWS/ to remove all traces.

export AWS_ACCESS_KEY_ID="..."
export AWS_SECRET_ACCESS_KEY="..."
export AWS_SESSION_TOKEN="..."
export AWS_DEFAULT_REGION="us-east-1"

# Isolation: block ~/.aws/ from being read accidentally.
# This ensures only the credentials above are used.
export AWS_CONFIG_FILE=/dev/null
export AWS_SHARED_CREDENTIALS_FILE=/dev/null

# Project paths
export PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")/bin" 2>/dev/null && pwd):$PATH"
