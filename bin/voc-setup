#!/usr/bin/env bash
# voc-setup — Validate Vocareum credentials and prepare the environment.
#
# Prerequisites:
#   1. Paste your Vocareum credentials into clAWS/.env (see .env.example)
#   2. Run: bin/voc-setup
#
# This script:
#   - Validates the .env file exists and has required fields
#   - Sources credentials (current shell session only — no system changes)
#   - Blocks ~/.aws/ from being used accidentally
#   - Verifies AWS connectivity and account identity
#   - Installs Terraform if not present in bin/
#
# Leave no trace: everything stays inside clAWS/. Delete the folder when done.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_FILE="$PROJECT_ROOT/.env"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

ok()   { echo -e "${GREEN}✓${NC} $1"; }
warn() { echo -e "${YELLOW}⚠${NC} $1"; }
fail() { echo -e "${RED}✗${NC} $1"; exit 1; }

echo "═══════════════════════════════════════════════════"
echo "  Vocareum Account Setup — clAWS IDP Testbed"
echo "═══════════════════════════════════════════════════"
echo ""

# ── Step 1: Check .env exists ──────────────────────────
if [ ! -f "$ENV_FILE" ]; then
  fail ".env file not found at $ENV_FILE

  Create it by copying .env.example:
    cp .env.example .env

  Then paste your Vocareum credentials into .env.
  Get them from: Vocareum → AWS Details"
fi

ok ".env file found"

# ── Step 2: Source and validate ────────────────────────
source "$ENV_FILE"

ERRORS=0

if [ -z "${AWS_ACCESS_KEY_ID:-}" ]; then
  echo -e "${RED}✗${NC} AWS_ACCESS_KEY_ID is missing"
  ERRORS=$((ERRORS + 1))
elif [[ ! "$AWS_ACCESS_KEY_ID" =~ ^ASIA ]]; then
  warn "AWS_ACCESS_KEY_ID does not start with ASIA (Vocareum uses temporary credentials)"
fi

if [ -z "${AWS_SECRET_ACCESS_KEY:-}" ]; then
  echo -e "${RED}✗${NC} AWS_SECRET_ACCESS_KEY is missing"
  ERRORS=$((ERRORS + 1))
fi

if [ -z "${AWS_SESSION_TOKEN:-}" ]; then
  echo -e "${RED}✗${NC} AWS_SESSION_TOKEN is missing"
  ERRORS=$((ERRORS + 1))
elif [ ${#AWS_SESSION_TOKEN} -lt 100 ]; then
  warn "AWS_SESSION_TOKEN looks too short (${#AWS_SESSION_TOKEN} chars). Vocareum tokens are typically 300+ chars. Check for copy-paste truncation."
fi

if [ $ERRORS -gt 0 ]; then
  fail "$ERRORS required field(s) missing in .env. See .env.example for format."
fi

ok "Credentials format validated"

# ── Step 3: Verify connectivity ────────────────────────
echo ""
echo "Verifying AWS connectivity..."

IDENTITY=$(aws sts get-caller-identity --output json 2>&1) || fail "AWS authentication failed. Check credentials in .env.

  Common causes:
  - Expired session (Vocareum sessions are time-limited)
  - Copy-paste error in credentials
  - Missing or truncated AWS_SESSION_TOKEN"

ACCOUNT=$(echo "$IDENTITY" | python3 -c "import sys,json; print(json.load(sys.stdin)['Account'])")
ARN=$(echo "$IDENTITY" | python3 -c "import sys,json; print(json.load(sys.stdin)['Arn'])")
REGION="${AWS_DEFAULT_REGION:-us-east-1}"

ok "Authenticated to AWS"
echo "    Account:  $ACCOUNT"
echo "    Role:     $ARN"
echo "    Region:   $REGION"

if [[ ! "$ARN" =~ voclabs ]]; then
  warn "Role does not contain 'voclabs' — this may not be a Vocareum account"
fi

# ── Step 4: Check Terraform ────────────────────────────
echo ""
TERRAFORM_BIN="$PROJECT_ROOT/bin/terraform"
TERRAFORM_VERSION="1.7.5"

if [ -x "$TERRAFORM_BIN" ]; then
  TF_VER=$("$TERRAFORM_BIN" version -json 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin)['terraform_version'])" 2>/dev/null || echo "unknown")
  ok "Terraform found: v$TF_VER"
else
  echo "Terraform not found in bin/. Installing v${TERRAFORM_VERSION}..."
  curl -fsSL "https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}/terraform_${TERRAFORM_VERSION}_linux_amd64.zip" -o /tmp/terraform.zip
  unzip -o /tmp/terraform.zip -d "$PROJECT_ROOT/bin/"
  rm /tmp/terraform.zip
  chmod +x "$TERRAFORM_BIN"
  ok "Terraform v${TERRAFORM_VERSION} installed to bin/"
fi

# ── Step 5: Summary ───────────────────────────────────
echo ""
echo "═══════════════════════════════════════════════════"
echo -e "${GREEN}  Setup complete.${NC}"
echo ""
echo "  Before running any AWS or Terraform command:"
echo ""
echo "    source .env"
echo ""
echo "  This sets credentials for the current terminal"
echo "  session only. No files are written outside clAWS/."
echo ""
echo "  When completely done, clean up with:"
echo ""
echo "    cd .. && rm -rf clAWS"
echo ""
echo "═══════════════════════════════════════════════════"
